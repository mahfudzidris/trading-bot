# ==============================
# Trading Bot — Environment Config
# ==============================
# Set MOCK_MODE=true for fully offline demo with generated data
# Set MOCK_MODE=false and fill in API keys for live trading

# Mode
MOCK_MODE=true

# Twelve Data (market data)
TWELVEDATA_API_KEY=your_twelvedata_api_key

# Alpaca (broker)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_PAPER=true

# DeepSeek (AI analysis)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat

# Trade Settings
SYMBOLS=AAPL,TSLA,MSFT,GOOGL,AMZN
TRADE_MAX_POSITION_SIZE=0.1
TRADE_STOP_LOSS_PCT=0.02
TRADE_TAKE_PROFIT_PCT=0.05

# Server
PORT=8000
DB_PATH=data/trading.db
